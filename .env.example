# Port the web app listens on (inside the container)
PORT=5000

# Directory the app scans for instructional video files.
# In Docker, bind-mount your folder to /media.
MEDIA_DIR=/media

# Path to the SQLite database (keep it on a persistent volume in Docker)
DB_PATH=/data/data.db

# Where generated video thumbnails are stored (keep on a persistent volume).
THUMBNAIL_DIR=/data/thumbnails

# Set to "true" ONLY to populate the library with sample instructionals on first
# run (useful for trying the UI). Leave unset for real installs — your library
# starts empty and you scan your own media folder.
# DEMO_SEED=true

# Thumbnails are generated from local video files with ffmpeg. By default the
# app will NOT fetch remote URLs for thumbnailing (to avoid server-side fetching
# of URLs you paste in). Set to "true" to also generate thumbnails for
# instructionals whose file is a remote http(s) URL.
# ALLOW_REMOTE_THUMBNAILS=false
